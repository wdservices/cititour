{
  "expo": {
    "name": "Citivas",
    "slug": "citivas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7FA"
    },
    "android": {
      "package": "com.cititour.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E88E5"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.cititour.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Citivas uses your location to show hotels, restaurants and events near you, and to switch to your current city automatically."
      }
    },
    "plugins": [
      "expo-location",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "017bffc2-8175-4c32-afbf-7f16a54139d1"
      }
    },
    "owner": "spellz49"
  }
}
