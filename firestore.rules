rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Businesses (also used for Events with category="Event") ──
    match /businesses/{businessId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // ── Business activity log (chat notifications, etc.) ──
      // Only the business owner can read their own activity feed. Writes
      // happen via sendMessage() in the app using the owner's/customer's
      // own auth context, not directly by an arbitrary third party.
      match /activityLog/{entryId} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }

      // ── Event ticket tiers ──
      // Read must be public (pricing needs to be visible pre-purchase, same
      // as the parent business doc). Create/update is restricted to the
      // event's own organizer OR a signed-in user completing a purchase —
      // this is intentionally broad on update (any authenticated user can
      // increment `sold`) because the client currently updates `sold` from
      // the buyer's own session, not a privileged backend. Tighten this to
      // a Cloud Function-only write once ticket purchases move server-side.
      match /tickets/{ticketId} {
        allow read: if true;
        allow create: if request.auth != null && (
          get(/databases/$(database)/documents/businesses/$(businessId)).data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
        );
        allow update: if request.auth != null;
        allow delete: if request.auth != null && (
          get(/databases/$(database)/documents/businesses/$(businessId)).data.organizerId == request.auth.uid ||
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
        );
      }
    }

    // ── Chats (business <-> customer messaging) ──
    // Only the two participants on a thread (business owner via ownerId,
    // or the customer themself) can read or write to it.
    match /chats/{chatId} {
      allow read: if request.auth != null && (
        resource.data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.customerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.customerId == request.auth.uid ||
        get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.ownerId == request.auth.uid
      );
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.customerId == request.auth.uid ||
          get(/databases/$(database)/documents/businesses/$(get(/databases/$(database)/documents/chats/$(chatId)).data.businessId)).data.ownerId == request.auth.uid
        );
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Purchased ticket records (top-level, separate from the tier
    // inventory subcollection above) ──
    // NOTE: no write path to this collection exists anywhere in the client
    // codebase as of this writing — EventTicketsPage.tsx only ever READS
    // from it (querying sales counts). This means either ticket purchases
    // aren't actually being recorded here yet (a real gap to close before
    // "tickets sold" figures can be trusted), or they're written through a
    // mechanism not yet found in this codebase. Read is allowed broadly for
    // now so the existing sales-count queries don't break; revisit the
    // write rule once the actual purchase-recording flow is confirmed.
    match /tickets/{ticketRecordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Marketplace Products ──
    match /marketplace/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // ── House Listings / Properties ──
    match /house_listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // ── Favourites ──
    match /favourites/{favouriteId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Wallets ──
    match /wallets/{walletId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;

      // ── Wallet transaction history ──
      // Owner can always read their own history. Broader authenticated read
      // is also allowed so the admin dashboard can aggregate revenue across
      // all users via a collectionGroup query — there's no custom-claims
      // admin-role system yet, so this is intentionally permissive for now.
      // Tighten to an admin-only custom claim once that exists.
      match /transactions/{transactionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ── Transactions ──
    match /transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Ads ──
    match /ads/{adId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // ── Feedback ──
    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // ── Reviews ──
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Catch-all: deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
